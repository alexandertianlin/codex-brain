# Optional local overrides for codex-brain.
# Copy this file to .env locally if your paths differ from the defaults.

CODEX_MEMORY_DB=<path-to-codex-memory>\index\memory.sqlite
CODEX_CDS_SCRIPTS=<path-to-codex-skills>\cds\scripts
CODEX_BRAIN_PYTHON=<path-to-codex-brain>\.venv\Scripts\python.exe

# Optional provider-specific keys. Do not commit real values.
ALLREALAI_API_KEY=
OPENAI_API_KEY=
